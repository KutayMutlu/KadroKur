# Yerel giriş / Supabase: Vercel ile aynı değişkenleri indirmek için (bir kez: npx vercel login, npx vercel link):
#   npm run env:pull
# Sonra dev sunucusunu yeniden başlatın: npm run dev
#
# Elle dolduracaksanız bu dosyayı kopyalayıp .env.local yapın.

# OAuth dönüş adresi (opsiyonel). Boş bırakınca tarayıcı adresi kullanılır.
# Yerelde ASLA Vercel URL'si yazmayın; aksi halde giriş production'a düşer.
# Tarayıcıda 127.0.0.1 kullanıyorsanız: http://127.0.0.1:3000
# Supabase → Redirect URLs listesinde /auth/callback tam adresi de olmalı (localhost ve 127.0.0.1 ayrı).
# NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# Eski dashboard adı (anon) veya yeni publishable key — biri yeterli
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
